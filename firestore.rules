rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function signedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roleName) {
      return signedIn() && (
        request.auth.token.role == roleName || 
        getUserData().role == roleName
      );
    }

    function isAdmin() {
      // Allow the specific master admin email or check the role
      return signedIn() && (
        request.auth.token.role == 'admin' || 
        getUserData().role == 'admin' ||
        request.auth.token.email == 'master@novarise.com'
      );
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isParent() {
      return hasRole('parent');
    }

    // Routes
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
      allow update: if signedIn() && request.auth.uid == uid && 
        request.resource.data.diff(resource.data).affectedKeys()
          .hasOnly(['profileImageUrl', 'displayName', 'phone', 'bloodGroup', 'updatedAt']);
    }

    match /students/{studentId} {
      allow read: if signedIn();
      allow update: if signedIn();
      allow write: if isAdmin();
    }

    match /transport_routes/{routeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isTeacher() && resource.data.classId in getUserData().assignedClassIds) ||
        (isParent() && request.auth.uid in get(/databases/$(database)/documents/classes/$(resource.data.classId)).data.parentUserIds) // Optional deep check
      );
      allow write: if isAdmin() || (isTeacher() && request.resource.data.classId in getUserData().assignedClassIds);
    }

    match /fee_invoices/{invoiceId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isParent() && request.auth.uid in get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentUserIds)
      );
      allow write: if isAdmin();
    }

    match /fee_payments/{paymentId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isParent() && request.auth.uid == resource.data.uploadedByUid)
      );
      allow create: if isParent();
      allow update: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isTeacher() && resource.data.classId in getUserData().assignedClassIds) ||
        isParent() // Parents need to see attendance for their kids' classes
      );
      allow write: if isAdmin() || (isTeacher() && request.resource.data.classId in getUserData().assignedClassIds);
    }

    match /classes/{classId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /lesson_records/{recordId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isTeacher() && resource.data.classId in getUserData().assignedClassIds) ||
        isParent()
      );
      allow write: if isAdmin() || (isTeacher() && request.resource.data.classId in getUserData().assignedClassIds);
    }
    
    match /import_jobs/{jobId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /notification_jobs/{jobId} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false; // Only written via Admin SDK in Cloud Functions
    }

    match /rate_limits/{limitId} {
      allow read: if false;
      allow write: if false; // Managed exclusively by Cloud Functions
    }
  }
}
