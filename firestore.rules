rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helpers
    function signedIn() {
      return request.auth != null;
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function hasRole(roleName) {
      return signedIn() && (
        request.auth.token.role == roleName || 
        getUserData().role == roleName
      );
    }

    function isAdmin() {
      return hasRole('admin');
    }

    function isTeacher() {
      return hasRole('teacher');
    }

    function isParent() {
      return hasRole('parent');
    }

    // Routes
    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow write: if isAdmin();
      // Allow profile update for own photo
      allow update: if signedIn() && request.auth.uid == uid && 
        request.resource.data.diff(resource.data).affectedKeys().hasOnly(['profileImageUrl', 'updatedAt']);
    }

    match /students/{studentId} {
      allow read: if signedIn() && (
        isAdmin() || 
        isTeacher() || 
        (isParent() && request.auth.uid in resource.data.parentUserIds)
      );
      allow write: if isAdmin();
    }

    match /transport_routes/{routeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /notices/{noticeId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /fee_invoices/{invoiceId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isParent() && request.auth.uid in get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentUserIds)
      );
      allow write: if isAdmin();
    }

    match /fee_payments/{paymentId} {
      allow read: if signedIn() && (
        isAdmin() || 
        (isParent() && request.auth.uid == resource.data.uploadedByUid)
      );
      allow create: if isParent();
      allow update: if isAdmin();
    }

    match /attendance/{attendanceId} {
      allow read: if signedIn();
      allow write: if isAdmin() || isTeacher();
    }

    match /classes/{classId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }
    
    match /import_jobs/{jobId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
