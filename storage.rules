rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    match /profiles/{uid} {
      allow read: if signedIn();
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /schoolapp/{schoolId}/{allPaths=**} {
      allow read: if signedIn();
      allow write: if signedIn(); // Simplify for the demo to avoid complex cross-service lookups
    }
  }
}
