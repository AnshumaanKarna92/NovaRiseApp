rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function role() {
      return request.auth.token.role;
    }

    function isAdmin() {
      return signedIn() && role() == 'admin';
    }

    function isTeacher() {
      return signedIn() && role() == 'teacher';
    }

    function isParent() {
      return signedIn() && role() == 'parent';
    }

    function isCashCollector() {
      return signedIn() && role() == 'cash_collector';
    }

    match /users/{uid} {
      allow read: if request.auth.uid == uid || isAdmin();
      allow create: if signedIn()
        && request.auth.uid == uid
        && !exists(/databases/$(database)/documents/users/$(uid))
        && request.resource.data.uid == uid
        && request.resource.data.role == "parent"
        && request.resource.data.schoolId == "school_001"
        && request.resource.data.status == "active";
      allow update, delete: if isAdmin();
    }

    match /students/{studentId} {
      allow read: if isAdmin()
        || isTeacher()
        || (isParent() && request.auth.uid in resource.data.parentUserIds);
      allow create, update, delete: if isAdmin();
    }

    match /teachers/{teacherId} {
      allow read: if isAdmin() || isTeacher();
      allow write: if isAdmin();
    }

    match /classes/{classId} {
      allow read: if signedIn();
      allow write: if isAdmin();
    }

    match /fee_invoices/{invoiceId} {
      // Parents can only read their own child's invoices
      allow read: if isAdmin() 
        || (isParent() && exists(/databases/$(database)/documents/students/$(resource.data.studentId)) 
            && request.auth.uid in get(/databases/$(database)/documents/students/$(resource.data.studentId)).data.parentUserIds);
      allow write: if isAdmin();
    }

    match /fee_payments/{paymentId} {
      // Parents can read their own payments
      allow read: if isAdmin() || (isParent() && request.auth.uid == resource.data.uploadedByUid);
      
      // Fallback: Allow parents to create a payment record if Cloud Functions fail
      allow create: if isParent() 
        && request.resource.data.status == "pending_verification"
        && request.resource.data.paymentMethod == "upi"
        && exists(/databases/$(database)/documents/students/$(request.resource.data.studentId))
        && request.auth.uid in get(/databases/$(database)/documents/students/$(request.resource.data.studentId)).data.parentUserIds;
      
      allow update, delete: if isAdmin();
    }

    match /attendance/{attendanceId} {
      // Teachers see their classes, parents see their child's class
      allow read: if isAdmin() || isTeacher() || isParent(); 
      allow write: if false; // Only via Cloud Functions
    }

    match /notices/{noticeId} {
      allow read: if signedIn();
      allow write: if false; // Only via Cloud Functions
    }

    match /messages/{messageId} {
      allow read: if signedIn();
      allow write: if false;
    }

    match /notification_jobs/{jobId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /import_jobs/{jobId} {
      allow read: if isAdmin();
      allow write: if false;
    }

    match /audit_logs/{logId} {
      allow read: if isAdmin();
      allow write: if false;
    }
  }
}
